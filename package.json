{
  "name": "@vibecontrols/vibe-plugin-ai-plandex",
  "version": "2026.509.2",
  "type": "module",
  "main": "./dist/index.js",
  "description": "Plandex AI agent provider for VibeControls",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "dev": "tsc --watch",
    "type:check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "lint": "echo skip lint",
    "test": "echo skip test",
    "format:check": "echo skip format",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run build && bun run test"
  },
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.509.1",
    "elysia": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@vibecontrols/agent": ">=2.0.0",
    "@vibecontrols/vibe-plugin-ai": "2026.509.1"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    }
  },
  "overrides": {
    "lodash": ">=4.17.21",
    "lodash-es": ">=4.17.21",
    "dompurify": ">=3.3.4",
    "fast-xml-parser": ">=4.5.5",
    "@xmldom/xmldom": ">=0.8.12",
    "swiper": ">=12.1.2",
    "brace-expansion": ">=1.1.13",
    "follow-redirects": ">=1.15.12",
    "smol-toml": ">=1.6.1",
    "axios": ">=1.15.0",
    "flatted": ">=3.4.1",
    "yaml": ">=2.8.3",
    "picomatch": ">=2.3.2",
    "immutable": ">=3.8.3",
    "minimatch": ">=3.1.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-ai-plandex.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-ai-plandex/issues"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://verdaccio.tooling.internal.burdenoff.com/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ]
}
